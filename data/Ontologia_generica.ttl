@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix am: <http://example.org/animanga-okg/ontology/> .

# ==========================================
# DEFINIZIONE DELLE CLASSI PRINCIPALI (I Nodi)
# ==========================================

am:Character a owl:Class ;
    rdfs:label "Personaggio Immaginario"@it ;
    owl:equivalentClass wd:Q211422 ;
    rdfs:comment "La classe di tutti i personaggi degli anime e manga."@it .

am:Series a owl:Class ;
    rdfs:label "Serie Anime o Manga"@it ;
    rdfs:comment "L'opera mediale in cui il personaggio appare."@it .

am:NarrativeRole a owl:Class ;
    rdfs:label "Ruolo Narrativo"@it ;
    rdfs:comment "La funzione strutturale del personaggio nella trama (es. Protagonista, Mentore)."@it .

am:Archetype a owl:Class ;
    rdfs:label "Archetipo / Trope"@it ;
    owl:equivalentClass wd:Q327333 ;
    rdfs:comment "Modello di comportamento o cliché narrativo (es. Tsundere, Eroe Shonen)."@it .

# ==========================================
# DEFINIZIONE DELLE PROPRIETÀ (Gli Archi)
# ==========================================

# 1. Apparizione nell'opera
am:appearsIn a owl:ObjectProperty ;
    owl:equivalentProperty wdt:P1441 ;
    rdfs:domain am:Character ; # Il soggetto DEVE essere un Personaggio
    rdfs:range am:Series .     # L'oggetto DEVE essere una Serie

# 2. Ruolo Narrativo
am:hasNarrativeRole a owl:ObjectProperty ;
    owl:equivalentProperty wdt:P4595 ;
    rdfs:domain am:Character ;
    rdfs:range am:NarrativeRole .

# 3. Archetipo Comportamentale (Il nostro Gap arricchito)
am:hasArchetype a owl:ObjectProperty ;
    owl:equivalentProperty wdt:P9071 ;
    rdfs:domain am:Character ;
    rdfs:range am:Archetype .

# 4. Tracciabilità dell'LLM (PROV-O)
prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:domain am:Archetype ; # L'assegnazione dell'archetipo...
    rdfs:range prov:Activity . # ...deve derivare da un'attività tracciabile (es. il prompt LLM)