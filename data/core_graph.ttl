am:Underdog a wd:Q327333 ; rdfs:label "Emarginato (Underdog)"@it .
am:Avenger a wd:Q327333 ; rdfs:label "Vendicatore"@it .
am:TragicVillain a wd:Q327333 ; rdfs:label "Cattivo Tragico"@it .
am:VillainProtagonist a wd:Q327333 ; rdfs:label "Protagonista Malvagio"@it .
am:EccentricGenius a wd:Q327333 ; rdfs:label "Genio Eccentrico"@it .
am:Trickster a wd:Q327333 ; rdfs:label "Trickster (Imbroglione cosmico)"@it .
