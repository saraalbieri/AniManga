# Tracciabilità delle inferenze (PROV-O) applicata all'intero set di arricchimento
am:GraphEnrichmentActivity a prov:Activity ;
    rdfs:label "Estrazione degli archetipi tramite elaborazione LLM e analisi testuale per il progetto AniManga O-KG"@it .