# 5. ONTOLOGIA ESTESA (Termini e Provenienza)
# ==========================================

# Mappatura dei Ruoli e Archetipi mancanti su Wikidata
am:MentorRole a wd:Q4595 ; rdfs:label "Mentore"@it .
