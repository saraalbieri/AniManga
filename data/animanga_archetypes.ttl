# Local vocabulary for anime and manga archetypes that are useful for analysis
# but are not always available as stable Wikidata entities.

animanga:ShonenProtagonist
    a animanga:LocalArchetype ;
    rdfs:label "shonen protagonist"@en ;
    rdfs:label "protagonista shonen"@it ;
    skos:broader wd:Q113946608 .

animanga:LoyalRival
    a animanga:LocalArchetype ;
    rdfs:label "loyal rival"@en ;
    rdfs:label "rivale leale"@it .

animanga:ComicReliefFighter
    a animanga:LocalArchetype ;
    rdfs:label "comic relief fighter"@en ;
    rdfs:label "combattente comico"@it .

animanga:DetectiveFoil
    a animanga:LocalArchetype ;
    rdfs:label "detective foil"@en ;
    rdfs:label "detective rivale"@it .

animanga:TragicAntihero
    a animanga:LocalArchetype ;
    rdfs:label "tragic antihero"@en ;
    rdfs:label "antieroe tragico"@it ;
    skos:broader wd:Q110910 .

