@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix animanga: <https://w3id.org/animanga/archetype/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

animanga:CharacterArchetypeStatementShape
    a sh:NodeShape ;
    sh:targetSubjectsOf wdt:P9071 ;
    rdfs:label "Vincolo sulle proposte P9071"@it ;
    sh:property [
        sh:path wdt:P9071 ;
        sh:minCount 1 ;
        sh:message "Ogni personaggio arricchito deve avere almeno un valore per wdt:P9071."@it
    ] .

animanga:LocalArchetypeShape
    a sh:NodeShape ;
    sh:targetClass animanga:LocalArchetype ;
    rdfs:label "Vincolo sugli archetipi locali"@it ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:message "Ogni archetipo locale deve avere almeno una label leggibile."@it
    ] .
