PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT DISTINCT ?personaggio ?personaggioLabel ?tipoPersonaggioLabel
WHERE {
  # 1. Inseriamo le tue 10 entità esatte
  VALUES ?opera { 
    wd:Q4431905 wd:Q642 wd:Q673 wd:Q104623150 wd:Q1834 
    wd:Q26971382 wd:Q28667972 wd:Q718624 wd:Q710324 wd:Q25929253 
  } 
  
  # 2. RICERCA OBBLIGATORIA: Estraiamo i personaggi
  # Senza OPTIONAL, le entità con 0 personaggi vengono ignorate
  ?opera wdt:P674 ?personaggio .
  
  # 3. Subquery: calcoliamo quanti personaggi ha in totale ogni opera valida
  {
    SELECT ?opera (COUNT(DISTINCT ?char) AS ?totalePersonaggi)
    WHERE {
      ?opera wdt:P674 ?char .
    }
    GROUP BY ?opera
  }

  # 4. Estrazione del "character type" (P9071). 
  # Questo rimane OPTIONAL perché ci interessa il personaggio anche se non ha un tipo definito
  OPTIONAL { ?personaggio wdt:P9071 ?tipoPersonaggio . }

  # 5. Label Service
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en". }
}
ORDER BY DESC(?tipoPersonaggioLabel) ?personaggioLabel