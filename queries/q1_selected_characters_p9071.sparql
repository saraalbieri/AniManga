PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

# Obiettivo: controllare se i 15 personaggi del campione hanno gia P9071.
SELECT ?anime ?animeLabel ?character ?characterLabel ?characterType ?characterTypeLabel
WHERE {
# Opere del corpus.
  VALUES ?anime { wd:Q710324 wd:Q25929253 wd:Q718624 }
# Personaggi scelti manualmente: 5 per ogni opera.
  VALUES ?character {
    wd:Q477948   # Monkey D. Luffy
    wd:Q858432   # Roronoa Zoro
    wd:Q877964   # Nami
    wd:Q1061765  # Sanji
    wd:Q1190653  # Nico Robin
    wd:Q931      # Naruto Uzumaki
    wd:Q1740     # Sasuke Uchiha
    wd:Q203240   # Sakura Haruno
    wd:Q1767     # Kakashi Hatake
    wd:Q1043344  # Itachi Uchiha
    wd:Q843545   # Light Yagami
    wd:Q52863    # L, Death Note
    wd:Q687038   # Misa Amane
    wd:Q2328583  # Ryuk
    wd:Q138008   # Near
  }

# Colleghiamo personaggio e opera usando entrambe le proprieta trovate in Wikidata.
  {
    ?character wdt:P1441 ?anime .
  }
  UNION
  {
    ?character wdt:P1080 ?anime .
  }

# P9071 = character type. OPTIONAL permette di vedere anche i personaggi senza valore.
  OPTIONAL { ?character wdt:P9071 ?characterType . }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,it". }
}
ORDER BY ?animeLabel ?characterLabel ?characterTypeLabel
