PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX schema: <http://schema.org/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

# Obiettivo: verificare che le tre opere scelte esistano in Wikidata.
# Usiamo QID gia verificati per evitare ambiguita nelle label.
SELECT DISTINCT ?work ?workLabel ?description
WHERE {
  VALUES ?work {
    wd:Q710324    # One Piece
    wd:Q25929253  # Naruto
    wd:Q718624    # Death Note
  }

# Recuperiamo la descrizione inglese esposta da schema:description.
  OPTIONAL {
    ?work schema:description ?description .
    FILTER(LANG(?description) = "en")
  }

# wikibase:label aggiunge automaticamente le label leggibili delle entita.
  SERVICE wikibase:label {
    bd:serviceParam wikibase:language "en,it".
  }
}
ORDER BY ?workLabel
