PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

# Obiettivo: isolare i personaggi del campione privi di character type.
SELECT ?character ?characterLabel
WHERE {
# Stesso campione di 15 personaggi usato nella query precedente.
  VALUES ?character {
    wd:Q477948 wd:Q858432 wd:Q877964 wd:Q1061765 wd:Q1190653
    wd:Q931 wd:Q1740 wd:Q203240 wd:Q1767 wd:Q1043344
    wd:Q843545 wd:Q52863 wd:Q687038 wd:Q2328583 wd:Q138008
  }

# Teniamo solo i personaggi per cui non esiste alcuna tripla P9071.
  FILTER NOT EXISTS { ?character wdt:P9071 ?characterType . }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,it". }
}
ORDER BY ?characterLabel
