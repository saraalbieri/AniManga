PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT ?property ?propertyLabel (COUNT(DISTINCT ?character) AS ?usageCount) ?totalCharacters
WHERE {
  # 1. Subquery: Calcoliamo il numero totale ASSOLUTO dei personaggi
  {
    SELECT (COUNT(DISTINCT ?c) AS ?totalCharacters) WHERE {
      VALUES ?item { wd:Q25929253 wd:Q26971382 wd:Q642 }
      ?item wdt:P674 ?c .
    }
  }
  
  # 2. Riprendiamo i personaggi e le loro proprietà
  VALUES ?item { wd:Q25929253 wd:Q26971382 wd:Q642 }
  ?item wdt:P674 ?character .
  
  # Usiamo [] (nodo vuoto) perché non ci interessa il valore in sé, 
  # ma solo il fatto che la proprietà sia utilizzata
  ?character ?propertyUri [] . 
  ?property wikibase:directClaim ?propertyUri .
  
  # 3. Label service per i nomi delle proprietà
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en". }
}
# 4. Raggruppiamo tutto per proprietà
GROUP BY ?property ?propertyLabel ?totalCharacters

# 5. La condizione chiave: tieni solo le proprietà usate meno del totale
HAVING (COUNT(DISTINCT ?character) < ?totalCharacters)

# Ordiniamo per mostrare prima le proprietà più usate (ma comunque non da tutti)
ORDER BY DESC(?usageCount)